# Used locally only for "yarn install" to get our paid plan icons
export FONT_AWESOME_TOKEN=""

# Dynamsoft license key for mobile document scanner
VITE_DYNAMSOFT_LICENSE_KEY=""

# RH extract presign HTTP API (POST /presign) — base URL from deploy output PresignHttpApiUrl
VITE_PRESIGN_S3_API_BASE_URL=""
# Bearer token matching PRESIGNED_API_TOKEN in the extract Secrets Manager secret
VITE_PRESIGNED_S3_API_TOKEN=""

# One time command to copy Scanbot WASM files to public/wasm/
# "postinstall": "cp -R node_modules/scanbot-web-sdk/bundle/bin/document-scanner/* public/wasm/"

# Rollbar access token for error reporting
VITE_ROLLBAR_ACCESS_TOKEN=""

# JustFix's auth-provider base URL
VITE_AUTH_PROVIDER_BASE_URL="http://0.0.0.0:8080"

# OAuth client id used for OTP token exchange
VITE_RH_OAUTH_CLIENT_ID=""

# OAuth client secret for confidential clients
VITE_RH_OAUTH_CLIENT_SECRET=""
